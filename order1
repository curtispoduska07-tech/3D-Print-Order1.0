<!DOCTYPE html>
<html>
<head>
  <title>3D Print Order</title>
  <style>
    body { font-family: Arial; padding: 20px; max-width: 400px; margin: auto; }
    input, button { width: 100%; padding: 10px; margin: 10px 0; }
    h2 { text-align: center; }
  </style>
</head>
<body>

<h2>3D Print Order</h2>

<label>Grams</label>
<input type="number" id="grams" oninput="calculate()">

<label>Hours</label>
<input type="number" id="hours" oninput="calculate()">

<h3 id="price">Estimated Price: $0.00</h3>

<button onclick="pay()">Pay with Venmo</button>

<script>
function calculate() {
  let grams = document.getElementById('grams').value || 0;
  let hours = document.getElementById('hours').value || 0;

  let pricePerGram = 0.024;
  let pricePerHour = 0.5;
  let machine = 0.1;
  let maintenance = 0.52;

  let total = (grams * pricePerGram) + 
              (hours * (pricePerHour + machine + maintenance));

  document.getElementById('price').innerText =
    "Estimated Price: $" + total.toFixed(2);
}

function pay() {
  let priceText = document.getElementById('price').innerText;
  let amount = priceText.replace("Estimated Price: $", "");

  let venmo = "https://venmo.com/@CurtisPoduska?txn=pay&amount=" 
              + amount + "&note=3D%20Print";

  window.open(venmo, "_blank");
}
</script>

</body>
</html>
